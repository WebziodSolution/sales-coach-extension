{
  "manifest_version": 3,
  "name": "360Pipe Sales Coach",
  "version": "1.0.0",
  "description": "Real-time AI sales coaching for Google Meet and Teams.",
  "permissions": [
    "storage",
    "scripting",
    "activeTab",
    "identity",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "cookies"
  ],
  "host_permissions": [
    "https://meet.google.com/*",
    "https://teams.cloud.microsoft/*",
    "https://teams.live.com/*",
    "https://*.webex.com/*",
    "https://api.openai.com/*",
    "https://meet.googleapis.com/*",
    "https://people.googleapis.com/*",
    "https://accounts.google.com/*",
    "https://oauth2.googleapis.com/*",
    "https://devapi.360pipe.com/*",
    "https://api.360pipe.com/*",
    "https://devwebapp.360pipe.com/*",
    "https://*.zoom.us/*",
    "https://zoom.us/*"
  ],
  "action": {
    "default_popup": "index.html"
  },
  "background": {
    "service_worker": "src/background/index.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://meet.google.com/*",
        "https://teams.cloud.microsoft/*",
        "https://teams.live.com/*",
        "https://*.webex.com/*",
        "https://*.zoom.us/*",
        "https://zoom.us/*"
      ],
      "js": [
        "src/content/index.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/*",
        "index.html"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}